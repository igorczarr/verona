datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 👩‍❤️‍👨 O Cofre do Casal (Agora com Streak e Dinâmicas)
model Relationship {
  id                String    @id @default(uuid())
  inviteCode        String    @unique @default(uuid())
  status            String    @default("PENDING")
  
  // Datas e Marcos
  startDate         DateTime? 
  firstDate         DateTime? 
  firstKiss         DateTime? 
  engagementDate    DateTime? 
  weddingDate       DateTime? 
  
  coverImageUrl     String?   

  // 🔥 Sistema de Streak e Gamificação
  streakCount       Int       @default(0) // Quantos dias seguidos responderam
  lastAnswerDate    DateTime? // Para calcular se o streak quebrou

  users             User[]    
  channels          Channel[] 
  posts             Post[]    
  messages          Message[] 
  dailyQuestions    DailyQuestion[] // Perguntas da IA exclusivas do casal
  dateIdeas         DateIdea[]      // O baú da Roleta

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// 👤 Perfil do Usuário
model User {
  id               String        @id @default(uuid())
  email            String        @unique 
  username         String        @unique
  passwordHash     String        
  name             String
  avatarUrl        String?
  
  // 🌡️ Termômetro Emocional (Ex: "exhausted", "romantic", "needy")
  moodStatus       String?       
  
  phoneNumber      String?

  relationshipId   String?
  relationship     Relationship? @relation(fields: [relationshipId], references: [id])

  posts            Post[]
  messages         Message[]
  favorites        Favorite[]
  answers          QuestionAnswer[] // Respostas às perguntas diárias

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

// 📺 Canais
model Channel {
  id               String        @id @default(uuid())
  name             String        
  description      String?
  relationshipId   String
  relationship     Relationship  @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  posts            Post[]        
  createdAt        DateTime      @default(now())
  @@unique([name, relationshipId])
}

// 📝 Posts da Timeline (Agora suportam Cápsula do Tempo)
model Post {
  id               String       @id @default(uuid())
  content          String
  imageUrl         String?
  
  // 🔒 Cápsula do Tempo: Se existir, o post fica bloqueado/borrado até esta data
  unlockAt         DateTime?    

  authorId         String
  author           User         @relation(fields: [authorId], references: [id])
  relationshipId   String
  relationship     Relationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  channelId        String
  channel          Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  
  parentId         String?
  parent           Post?        @relation("Thread", fields: [parentId], references: [id])
  replies          Post[]       @relation("Thread")

  favorites        Favorite[]
  createdAt        DateTime     @default(now())
}

// 💬 Chat Privado
model Message {
  id               String       @id @default(uuid())
  content          String
  senderId         String
  sender           User         @relation(fields: [senderId], references: [id])
  relationshipId   String
  relationship     Relationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  favorites        Favorite[]
  createdAt        DateTime     @default(now())
}

// ❓ A Pergunta do Dia (Gerada pela IA)
model DailyQuestion {
  id             String           @id @default(uuid())
  text           String           // O texto da pergunta gerada
  category       String           // "DEEP", "FUN", "SPICY"
  date           DateTime         @default(now()) // O dia em que a pergunta é válida
  
  relationshipId String
  relationship   Relationship     @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  
  answers        QuestionAnswer[] // As respostas do Igor e da Julieta

  @@unique([date, relationshipId]) // Apenas UMA pergunta por dia para o casal
}

// ✍️ A Resposta à Pergunta
model QuestionAnswer {
  id         String        @id @default(uuid())
  content    String
  
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  
  questionId String
  question   DailyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime      @default(now())

  @@unique([userId, questionId]) // O usuário só pode responder uma vez por pergunta
}

// 🎲 Roleta de Encontros (Date Ideas)
model DateIdea {
  id             String       @id @default(uuid())
  title          String
  category       String       // "FUN", "ROMANTIC", "SPICY"
  isCompleted    Boolean      @default(false) // Permite marcar como feito
  
  relationshipId String
  relationship   Relationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
}

// ⭐ Favoritos
model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id])
  messageId String?
  message   Message? @relation(fields: [messageId], references: [id])
  createdAt DateTime @default(now())
}